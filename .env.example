# ──────────────────────────────────────────────────────────────
# Demo chat — server-side environment
# Copy to `.env` and fill in. None of these reach the browser.
# ──────────────────────────────────────────────────────────────

# ─── n8n chatbot webhook (primary upstream) ─────────────────────
# Production path (preferred) — does not require "Execute" on the
# n8n canvas. The chat from the portfolio site hits this URL.
N8N_WEBHOOK_URL=https://n8n.ananalmasri.com/webhook/chatbot

# Test path — only works after clicking "Execute" on the n8n canvas.
# Use this for hand-testing workflow changes before promoting them to
# the production path. Switch to it with USE_N8N_TEST=true.
N8N_WEBHOOK_TEST_URL=https://n8n.ananalmasri.com/webhook-test/chatbot

# Set to "true" to route all /api/chat traffic to the test webhook
# (you must click Execute on the n8n canvas first). Leave "false" in
# production.
USE_N8N_TEST=false

# ─── Admin login (Telegram OTP via n8n) ────────────────────────
# The n8n webhook that issues/verifies the one-time code sent to
# Telegram. Proxied server-side so the browser never talks to n8n
# directly for this.
ADMIN_OTP_WEBHOOK_URL=https://n8n.ananalmasri.com/webhook/admin-login

# Secret used to sign the admin session cookie (HMAC-SHA256). Required
# for /dashboard login to work — generate with e.g. `openssl rand -hex 32`.
# Without it, verify-otp will refuse to issue a session.
ADMIN_SESSION_SECRET=

# ─── OpenRouter fallback (optional) ────────────────────────────
# If the n8n webhook fails, the server will try OpenRouter with this
# model. Without an API key, /api/chat returns a `server-fallback`
# message and the demo continues to work via the local intent-router.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# ─── Dev-only: Postman-mirror endpoint ─────────────────────────
# Set to "true" to expose /api/chat-test, a dev-only endpoint that
# forwards a literal Postman body to the n8n webhook (skipping the
# identity gate, rate limit, and chat-log). Pair with `?dev=1` on the
# chat card to reveal the [POSTMAN] trigger. NEVER enable in
# production.
ENABLE_TEST_ENDPOINT=false

# ─── Misc ──────────────────────────────────────────────────────
# Per-client chat-log directory (gitignored).
CHAT_LOG_DIR=./data

# Per-request model timeout in ms.
CHAT_TIMEOUT_MS=60000

# Public port (also used by the SPA host + /api/stats).
PORT=8080
STATIC_DIR=./dist
